{
    "name": "inwebo/benchmark-csv-reader",
    "description": "PHP csv readers benchmark : inwebo/csv-reader VS league/csv",
    "type": "project",
    "require": {
        "php": "^8.1",
        "inwebo/csv-reader": "^1.0",
        "league/csv": "^9.28",
        "phpbench/phpbench": "^1.6"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Inwebo\\BenchmarkCsvReader\\": "src/"
        }
    },
    "authors": [
        {
            "name": "inwebo",
            "email": "github@inwebo.net"
        }
    ],
    "minimum-stability": "stable",
    "scripts": {
      "generate":       "php -d max_execution_time=0 generate.php",
      "bench":          "php -d max_execution_time=0 vendor/bin/phpbench run --report=report_plot --output=html",
      "bench:inwebo":   "vendor/bin/phpbench run --filter=InweboCsvReaderBenchmark --report=report_plot --output=html",
      "bench:league":   "vendor/bin/phpbench run --filter=LeagueCsvBenchmark --report=report_plot",
      "bench:store":    "vendor/bin/phpbench run --report=report_plot --store"
    }
}
